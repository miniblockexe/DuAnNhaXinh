@{
    int currentPage = ViewData["CurrentPage"] != null ? (int)ViewData["CurrentPage"]!
                    : ViewBag.CurrentPage != null ? (int)ViewBag.CurrentPage
                    : ViewBag.Page != null ? (int)ViewBag.Page
                    : 1;

    int totalPages = ViewData["TotalPages"] != null ? (int)ViewData["TotalPages"]!
                    : (int)(ViewBag.TotalPages ?? 1);

    string action = ViewData["Action"]?.ToString() ?? "Index";

    string? keyword = ViewData["Keyword"]?.ToString() ?? ViewBag.Keyword as string;
    int? categoryId = ViewBag.CategoryId as int?;
    object? status = ViewBag.Status;
}

@if (totalPages > 1)
{
    int startPage = Math.Max(1, currentPage - 2);
    int endPage = Math.Min(totalPages, startPage + 4);
    if (endPage - startPage < 4) startPage = Math.Max(1, endPage - 4);

    <nav aria-label="Phân trang" class="mt-3">
        <ul class="pagination pagination-sm justify-content-center mb-0">

            @if (startPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="@action"
                       asp-route-page="1"
                       asp-route-keyword="@keyword"
                       asp-route-categoryId="@categoryId"
                       asp-route-status="@status"
                       title="Trang đầu">
                        <i class="bi bi-chevron-double-left"></i>
                    </a>
                </li>
            }

            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="@action"
                   asp-route-page="@(currentPage - 1)"
                   asp-route-keyword="@keyword"
                   asp-route-categoryId="@categoryId"
                   asp-route-status="@status"
                   title="Trang trước">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>

            @for (int p = startPage; p <= endPage; p++)
            {
                <li class="page-item @(p == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="@action"
                       asp-route-page="@p"
                       asp-route-keyword="@keyword"
                       asp-route-categoryId="@categoryId"
                       asp-route-status="@status">@p</a>
                </li>
            }

            <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="@action"
                   asp-route-page="@(currentPage + 1)"
                   asp-route-keyword="@keyword"
                   asp-route-categoryId="@categoryId"
                   asp-route-status="@status"
                   title="Trang sau">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
            @if (endPage < totalPages)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="@action"
                       asp-route-page="@totalPages"
                       asp-route-keyword="@keyword"
                       asp-route-categoryId="@categoryId"
                       asp-route-status="@status"
                       title="Trang cuối">
                        <i class="bi bi-chevron-double-right"></i>
                    </a>
                </li>
            }

        </ul>
        <div class="text-center text-muted small mt-1">
            Trang @currentPage / @totalPages
        </div>
    </nav>
}
