@model List<NhaXinh.Models.ApplicationUser>

@{
    ViewData["Title"] = "Quản lý người dùng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
    int totalCount = ViewBag.TotalCount;
    string? keyword = ViewBag.Keyword;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">
        <i class="bi bi-people me-2 text-primary"></i>Người dùng
        <span class="badge bg-secondary ms-1 fs-6">@totalCount</span>
    </h4>
</div>

@* Search *@
<div class="card shadow-sm mb-3">
    <div class="card-body py-2 px-3">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="keyword" value="@keyword"
                   class="form-control form-control-sm" placeholder="Tìm tên, email..." style="max-width:320px;" />
            <button class="btn btn-sm btn-outline-primary">
                <i class="bi bi-search"></i> Tìm
            </button>
            @if (!string.IsNullOrEmpty(keyword))
            {
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-x"></i> Xoá lọc
                </a>
            }
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width:50px">#</th>
                    <th>Họ tên / Email</th>
                    <th style="width:160px">Số điện thoại</th>
                    <th style="width:130px" class="text-center">Ngày đăng ký</th>
                    <th style="width:110px" class="text-center">Trạng thái</th>
                    <th style="width:130px" class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="bi bi-people fs-3 d-block mb-2"></i>
                            Không tìm thấy người dùng nào.
                        </td>
                    </tr>
                }
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="text-muted ps-3">
                            @if (!string.IsNullOrEmpty(user.AvatarUrl))
                            {
                                <img src="@user.AvatarUrl" alt="@user.FullName"
                                     style="width:32px;height:32px;object-fit:cover;border-radius:50%;" />
                            }
                            else
                            {
                                <span class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center"
                                      style="width:32px;height:32px;font-size:.75rem;font-weight:600;">
                                    @(user.FullName.Length > 0 ? user.FullName[0].ToString().ToUpper() : "?")
                                </span>
                            }
                        </td>
                        <td>
                            <div class="fw-semibold">@user.FullName</div>
                            <small class="text-muted">@user.Email</small>
                        </td>
                        <td>
                            <small>@(user.PhoneNumber ?? "—")</small>
                        </td>
                        <td class="text-center">
                            <small>@user.CreatedAt.ToString("dd/MM/yyyy")</small>
                        </td>
                        <td class="text-center">
                            @if (user.IsActive)
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Đã khoá</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Detail" asp-route-id="@user.Id"
                               class="btn btn-sm btn-outline-secondary me-1" title="Chi tiết">
                                <i class="bi bi-eye"></i>
                            </a>
                            @if (user.IsActive)
                            {
                                <form asp-action="ToggleActive" method="post" class="d-inline"
                                      onsubmit="return confirm('Khoá tài khoản «@user.FullName»?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <input type="hidden" name="isActive" value="false" />
                                    <button class="btn btn-sm btn-outline-danger" title="Khoá tài khoản">
                                        <i class="bi bi-lock"></i>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="ToggleActive" method="post" class="d-inline"
                                      onsubmit="return confirm('Mở khoá tài khoản «@user.FullName»?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <input type="hidden" name="isActive" value="true" />
                                    <button class="btn btn-sm btn-outline-success" title="Mở khoá">
                                        <i class="bi bi-unlock"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<partial name="_Pagination" view-data="ViewData" />
