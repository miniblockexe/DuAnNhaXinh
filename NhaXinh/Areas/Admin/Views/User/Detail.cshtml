@model NhaXinh.Models.ApplicationUser

@{
    ViewData["Title"] = "Chi tiết người dùng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h4 class="mb-0 fw-bold"><i class="bi bi-person-lines-fill me-2 text-primary"></i>Chi tiết người dùng</h4>
</div>

<div class="row g-4">

    <div class="col-lg-4">
        <div class="card shadow-sm text-center">
            <div class="card-body py-4">
                @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                {
                    <img src="@Model.AvatarUrl" alt="@Model.FullName"
                         class="rounded-circle border mb-3 mx-auto d-block"
                         style="width:90px;height:90px;object-fit:cover;" />
                }
                else
                {
                    <div class="bg-primary text-white rounded-circle d-flex mx-auto align-items-center justify-content-center mb-3"
                         style="width:90px;height:90px;font-size:2rem;font-weight:700;">
                        @(Model.FullName.Length > 0 ? Model.FullName[0].ToString().ToUpper() : "?")
                    </div>
                }

                <h5 class="fw-bold mb-1">@Model.FullName</h5>
                <div class="text-muted small mb-3">@Model.Email</div>

                @if (Model.IsActive)
                {
                    <span class="badge bg-success px-3 py-2">
                        <i class="bi bi-check-circle me-1"></i>Đang hoạt động
                    </span>
                }
                else
                {
                    <span class="badge bg-danger px-3 py-2">
                        <i class="bi bi-lock me-1"></i>Đã khoá
                    </span>
                }

                <div class="mt-4 d-grid gap-2 px-2">
                    @if (Model.IsActive)
                    {
                        <form asp-action="ToggleActive" method="post"
                              onsubmit="return confirm('Khoá tài khoản này?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="isActive" value="false" />
                            <button class="btn btn-outline-danger w-100">
                                <i class="bi bi-lock me-1"></i> Khoá tài khoản
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="ToggleActive" method="post"
                              onsubmit="return confirm('Mở khoá tài khoản này?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="isActive" value="true" />
                            <button class="btn btn-outline-success w-100">
                                <i class="bi bi-unlock me-1"></i> Mở khoá tài khoản
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>

        @{
            var currentRoles = ViewBag.CurrentRoles as IList<string> ?? new List<string>();
            var allRoles = ViewBag.AllRoles as List<string> ?? new List<string>();
            var availableRoles = allRoles.Except(currentRoles).ToList();
        }

        <div class="card shadow-sm mt-3">
            <div class="card-header fw-semibold py-2">
                <i class="bi bi-shield-lock me-1"></i> Phân quyền
            </div>
            <div class="card-body">
                <p class="fw-semibold mb-2">Quyền hiện tại:</p>
                @if (currentRoles.Any())
                {
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        @foreach (var role in currentRoles)
                        {
                            <form asp-action="RemoveRole" asp-controller="User"
                                  asp-area="Admin" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@Model.Id" />
                                <input type="hidden" name="role" value="@role" />
                                <button type="submit" class="badge bg-primary border-0 d-flex align-items-center gap-1"
                                        onclick="return confirm('Xóa quyền @role?')"
                                        style="font-size:.85rem; cursor:pointer;">
                                    @role <i class="bi bi-x"></i>
                                </button>
                            </form>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mb-3">Chưa có quyền nào.</p>
                }

                @if (availableRoles.Any())
                {
                    <p class="fw-semibold mb-2">Gán quyền:</p>
                    <form asp-action="AssignRole" asp-controller="User"
                          asp-area="Admin" method="post" class="d-flex gap-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="userId" value="@Model.Id" />
                        <select name="role" class="form-select w-auto">
                            @foreach (var role in availableRoles)
                            {
                                <option value="@role">@role</option>
                            }
                        </select>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-plus-lg me-1"></i>Gán quyền
                        </button>
                    </form>
                }
                else
                {
                    <p class="text-muted">Người dùng đã có tất cả quyền.</p>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card shadow-sm mb-3">
            <div class="card-header fw-semibold py-2">
                <i class="bi bi-person me-1"></i> Thông tin tài khoản
            </div>
            <div class="card-body">
                <table class="table table-borderless table-sm mb-0">
                    <tbody>
                        <tr>
                            <td class="text-muted fw-semibold" style="width:160px">Họ tên</td>
                            <td>@Model.FullName</td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-semibold">Email</td>
                            <td>
                                @Model.Email
                                @if (Model.EmailConfirmed)
                                {
                                    <span class="badge bg-success ms-1">Đã xác nhận</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark ms-1">Chưa xác nhận</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-semibold">Số điện thoại</td>
                            <td>@(Model.PhoneNumber ?? "—")</td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-semibold">Địa chỉ</td>
                            <td>@(Model.Address ?? "—")</td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-semibold">Ngày đăng ký</td>
                            <td>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-semibold">Đăng nhập 2 lớp</td>
                            <td>
                                @if (Model.TwoFactorEnabled)
                                {
                                    <span class="badge bg-success">Bật</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Tắt</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-semibold">Lần đăng nhập sai</td>
                            <td>@Model.AccessFailedCount lần</td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-semibold">Bị khoá đến</td>
                            <td>
                                @if (Model.LockoutEnd.HasValue && Model.LockoutEnd > DateTimeOffset.Now)
                                {
                                    <span class="text-danger">@Model.LockoutEnd.Value.LocalDateTime.ToString("dd/MM/yyyy HH:mm")</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header fw-semibold py-2 d-flex justify-content-between align-items-center">
                <span><i class="bi bi-cart-check me-1"></i> Đơn hàng</span>
                <span class="badge bg-primary">@Model.Orders.Count đơn</span>
            </div>
            <div class="card-body p-0">
                @if (!Model.Orders.Any())
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-inbox d-block mb-1"></i>Chưa có đơn hàng nào.
                    </div>
                }
                else
                {
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Mã đơn</th>
                                <th class="text-end">Tổng tiền</th>
                                <th class="text-center">Trạng thái</th>
                                <th class="text-center">Ngày đặt</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.Orders.OrderByDescending(o => o.CreatedAt))
                            {
                                <tr>
                                    <td>
                                        <a asp-area="Admin" asp-controller="Order" asp-action="Detail"
                                           asp-route-id="@order.Id" class="text-decoration-none">
                                            #@order.Id
                                        </a>
                                    </td>
                                    <td class="text-end fw-semibold">
                                        @order.TotalAmount.ToString("N0") ₫
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-secondary">@order.Status</span>
                                    </td>
                                    <td class="text-center">
                                        <small>@order.CreatedAt.ToString("dd/MM/yyyy")</small>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

    </div>
</div>
