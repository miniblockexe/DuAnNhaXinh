@model NhaXinh.Models.Banner

@{
    ViewData["Title"] = "Thêm Banner";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h4 class="mb-0 fw-bold"><i class="bi bi-image me-2 text-primary"></i>Thêm Banner mới</h4>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold">
                            Tiêu đề <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Title" class="form-control" placeholder="Ví dụ: Khuyến mãi mùa hè" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SubTitle" class="form-label fw-semibold">Phụ đề</label>
                        <input asp-for="SubTitle" class="form-control" placeholder="Mô tả ngắn (tuỳ chọn)" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="LinkUrl" class="form-label fw-semibold">URL liên kết</label>
                        <input asp-for="LinkUrl" class="form-control" placeholder="https://..." />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="DisplayOrder" class="form-label fw-semibold">Thứ tự hiển thị</label>
                            <input asp-for="DisplayOrder" type="number" min="0" class="form-control" />
                            <small class="text-muted">Số nhỏ hơn hiển thị trước.</small>
                        </div>
                        <div class="col-md-6 mb-3 d-flex align-items-end">
                            <div class="form-check form-switch ms-1 pb-2">
                                <input asp-for="IsActive" class="form-check-input" role="switch" checked />
                                <label asp-for="IsActive" class="form-check-label fw-semibold">Kích hoạt</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            Ảnh banner <span class="text-danger">*</span>
                        </label>
                        <input type="file" name="imageFile" id="imageFile" accept="image/*"
                               class="form-control"
                               onchange="previewImg(this,'imgPreview')" />
                        <span class="text-danger small" id="imageError"></span>
                        <div class="mt-2">
                            <img id="imgPreview" src="#" alt="Preview"
                                 class="d-none rounded border"
                                 style="max-height:160px;max-width:100%;object-fit:cover;" />
                        </div>
                        <small class="text-muted">Khuyến nghị: 1400×500 px, PNG/JPG/WEBP.</small>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-save me-1"></i> Lưu banner
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Huỷ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
