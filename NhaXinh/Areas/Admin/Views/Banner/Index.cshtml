@model List<NhaXinh.Models.Banner>

@{
    ViewData["Title"] = "Quản lý Banner";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold"><i class="bi bi-image me-2 text-primary"></i>Banner quảng cáo</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Thêm banner
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width:60px" class="text-center">STT</th>
                    <th style="width:140px" class="text-center">Hình ảnh</th>
                    <th>Tiêu đề</th>
                    <th>Link</th>
                    <th style="width:100px" class="text-center">Thứ tự</th>
                    <th style="width:110px" class="text-center">Hiển thị</th>
                    <th style="width:130px" class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">Chưa có banner nào.</td>
                    </tr>
                }
                @foreach (var banner in Model)
                {
                    <tr id="banner-row-@banner.Id">
                        <td class="text-center text-muted">@banner.DisplayOrder</td>
                        <td class="text-center">
                            <img src="@banner.ImageUrl" alt="@banner.Title"
                                 style="width:110px;height:55px;object-fit:cover;border-radius:6px;border:1px solid #dee2e6;" />
                        </td>
                        <td>
                            <strong>@banner.Title</strong>
                            @if (!string.IsNullOrEmpty(banner.SubTitle))
                            {
                                <br />
                                <small class="text-muted">@banner.SubTitle</small>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(banner.LinkUrl))
                            {
                                <a href="@banner.LinkUrl" target="_blank" class="text-truncate d-inline-block"
                                   style="max-width:180px;">@banner.LinkUrl</a>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-center">@banner.DisplayOrder</td>
                        <td class="text-center">
                            <div class="form-check form-switch d-inline-flex justify-content-center">
                                <input class="form-check-input toggle-active" type="checkbox"
                                       data-id="@banner.Id"
                                @(banner.IsActive ? "checked" : "")
                                       style="cursor:pointer;" />
                            </div>
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@banner.Id"
                               class="btn btn-sm btn-outline-primary me-1" title="Sửa">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@banner.Id" method="post"
                                  class="d-inline"
                                  onsubmit="return confirm('Xoá banner «@banner.Title»?')">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger" title="Xoá">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    @Html.AntiForgeryToken()
    <script>
        document.querySelectorAll('.toggle-active').forEach(function (chk) {
            chk.addEventListener('change', function () {
                const id = this.dataset.id;
                const self = this;
                fetch('@Url.Action("ToggleActive")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''
                    },
                    body: 'id=' + id
                })
                .then(r => r.json())
                .then(data => {
                    if (!data.success) {
                        self.checked = !self.checked;
                        alert('Cập nhật thất bại, thử lại.');
                    }
                });
            });
        });
    </script>
}
