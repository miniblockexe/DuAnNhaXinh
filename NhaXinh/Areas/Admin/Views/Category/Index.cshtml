@model List<NhaXinh.Models.Category>

@{
    ViewData["Title"] = "Quản lý danh mục";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold"><i class="bi bi-folder2-open me-2 text-primary"></i>Danh mục sản phẩm</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Thêm danh mục
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width:60px">#</th>
                    <th>Tên danh mục</th>
                    <th style="width:100px" class="text-center">Ảnh</th>
                    <th style="width:110px" class="text-center">Thứ tự</th>
                    <th style="width:110px" class="text-center">Trạng thái</th>
                    <th style="width:140px" class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">Chưa có danh mục nào.</td>
                    </tr>
                }
                @foreach (var parent in Model)
                {
                    <tr class="table-secondary">
                        <td>@parent.Id</td>
                        <td>
                            <i class="bi bi-folder-fill text-warning me-2"></i>
                            <strong>@parent.Name</strong>
                            <small class="text-muted ms-2">/@parent.Slug</small>
                        </td>
                        <td class="text-center">
                            @if (!string.IsNullOrEmpty(parent.ImageUrl))
                            {
                                <img src="@parent.ImageUrl" alt="@parent.Name"
                                     style="width:40px;height:40px;object-fit:cover;border-radius:6px;" />
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-center">@parent.DisplayOrder</td>
                        <td class="text-center">
                            @if (parent.IsActive)
                            {
                                <span class="badge bg-success">Hiển thị</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Ẩn</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@parent.Id"
                               class="btn btn-sm btn-outline-primary me-1" title="Sửa">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@parent.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Xoá danh mục «@parent.Name»?')">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger" title="Xoá">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>

                    @foreach (var sub in parent.SubCategories.OrderBy(s => s.DisplayOrder))
                    {
                        <tr>
                            <td class="ps-4 text-muted">@sub.Id</td>
                            <td class="ps-4">
                                <i class="bi bi-chevron-right text-muted me-1"></i>
                                <i class="bi bi-tag text-primary me-1"></i>
                                @sub.Name
                                <small class="text-muted ms-2">/@sub.Slug</small>
                            </td>
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(sub.ImageUrl))
                                {
                                    <img src="@sub.ImageUrl" alt="@sub.Name"
                                         style="width:36px;height:36px;object-fit:cover;border-radius:6px;" />
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-center">@sub.DisplayOrder</td>
                            <td class="text-center">
                                @if (sub.IsActive)
                                {
                                    <span class="badge bg-success">Hiển thị</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Ẩn</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@sub.Id"
                                   class="btn btn-sm btn-outline-primary me-1" title="Sửa">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@sub.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Xoá danh mục «@sub.Name»?')">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger" title="Xoá">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
