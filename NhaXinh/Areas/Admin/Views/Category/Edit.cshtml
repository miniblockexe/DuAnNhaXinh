@model NhaXinh.Models.Category

@{
    ViewData["Title"] = "Sửa danh mục";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h4 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2 text-primary"></i>Sửa danh mục</h4>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <input asp-for="CreatedAt" type="hidden" />
                    <input type="hidden" name="existingImage" value="@Model.ImageUrl" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">Tên danh mục <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Slug" class="form-label fw-semibold">Slug</label>
                        <input asp-for="Slug" class="form-control" />
                        <span asp-validation-for="Slug" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ParentId" class="form-label fw-semibold">Danh mục cha</label>
                        <select asp-for="ParentId" asp-items="ViewBag.ParentCategories" class="form-select">
                            <option value="">— Là danh mục gốc —</option>
                        </select>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="DisplayOrder" class="form-label fw-semibold">Thứ tự hiển thị</label>
                            <input asp-for="DisplayOrder" type="number" min="0" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3 d-flex align-items-end">
                            <div class="form-check form-switch ms-1 pb-2">
                                <input asp-for="IsActive" class="form-check-input" role="switch" />
                                <label asp-for="IsActive" class="form-check-label fw-semibold">Hiển thị</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Ảnh danh mục</label>
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="mb-2">
                                <img id="imgPreview" src="@Model.ImageUrl" alt="@Model.Name"
                                     class="rounded border"
                                     style="max-height:140px;max-width:100%;object-fit:cover;" />
                            </div>
                        }
                        else
                        {
                            <div class="mb-2">
                                <img id="imgPreview" src="#" alt="Preview"
                                     class="d-none rounded border"
                                     style="max-height:140px;max-width:100%;object-fit:cover;" />
                            </div>
                        }
                        <input type="file" name="imageFile" accept="image/*" class="form-control"
                               onchange="previewImg(this,'imgPreview')" />
                        <small class="text-muted">Để trống nếu không muốn thay ảnh.</small>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-save me-1"></i> Lưu thay đổi
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Huỷ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
