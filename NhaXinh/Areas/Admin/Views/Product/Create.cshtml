@using NhaXinh.Models
@model Product
@{
    ViewData["Title"] = "Thêm sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var categories = ViewBag.Categories as List<Category> ?? new();
}

<div class="d-flex align-items-center gap-2 mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h5 class="fw-bold mb-0">Thêm sản phẩm mới</h5>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

    <div class="row g-3">

        <div class="col-lg-8">
            <div class="content-card p-4 mb-3">
                <h6 class="fw-semibold mb-3">Thông tin cơ bản</h6>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-medium">Tên sản phẩm <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" placeholder="Nhập tên sản phẩm..." id="nameInput" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Slug" class="form-label fw-medium">Slug (URL)</label>
                    <input asp-for="Slug" class="form-control" placeholder="tu-dong-tao-tu-ten" id="slugInput" />
                    <span asp-validation-for="Slug" class="text-danger small"></span>
                    <div class="form-text">Để trống sẽ tự động tạo từ tên.</div>
                </div>

                <div class="mb-3">
                    <label asp-for="ShortDescription" class="form-label fw-medium">Mô tả ngắn</label>
                    <textarea asp-for="ShortDescription" class="form-control" rows="2"
                              placeholder="Mô tả ngắn hiển thị trên danh sách..."></textarea>
                </div>

                <div class="mb-0">
                    <label asp-for="Description" class="form-label fw-medium">Mô tả chi tiết</label>
                    <textarea asp-for="Description" class="form-control" rows="5"
                              placeholder="Mô tả đầy đủ về sản phẩm..."></textarea>
                </div>
            </div>

            <div class="content-card p-4">
                <h6 class="fw-semibold mb-3">Giá & Tồn kho</h6>
                <div class="row g-3">
                    <div class="col-sm-4">
                        <label asp-for="Price" class="form-label fw-medium">Giá gốc (₫) <span class="text-danger">*</span></label>
                        <input asp-for="Price" type="number" min="0" class="form-control" placeholder="0" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="col-sm-4">
                        <label asp-for="DiscountPrice" class="form-label fw-medium">Giá khuyến mãi (₫)</label>
                        <input asp-for="DiscountPrice" type="number" min="0" class="form-control" placeholder="Để trống nếu không có" />
                        <span asp-validation-for="DiscountPrice" class="text-danger small"></span>
                    </div>
                    <div class="col-sm-4">
                        <label asp-for="StockQuantity" class="form-label fw-medium">Số lượng tồn kho <span class="text-danger">*</span></label>
                        <input asp-for="StockQuantity" type="number" min="0" class="form-control" placeholder="0" />
                        <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="content-card p-4 mb-3">
                <h6 class="fw-semibold mb-3">Ảnh đại diện</h6>

                <div class="mb-2 text-center">
                    <img id="previewImg" src="#" alt="Preview"
                         class="img-fluid rounded border d-none"
                         style="max-height:200px;object-fit:cover;width:100%;" />
                    <div id="noImgPlaceholder" class="bg-light rounded border d-flex align-items-center
                         justify-content-center text-muted" style="height:150px;">
                        <div class="text-center">
                            <i class="bi bi-image fs-2"></i>
                            <div class="small mt-1">Chưa có ảnh</div>
                        </div>
                    </div>
                </div>

                <input type="file" name="imageFile" id="imageFile" accept="image/*" data-preview="#previewImg" data-preview-hide="#noImgPlaceholder"
                       class="form-control form-control-sm" />
                <div class="form-text">JPG, PNG, WEBP – tối đa 5MB.</div>
            </div>

            <div class="content-card p-4 mb-3">
                <h6 class="fw-semibold mb-3">Ảnh phụ</h6>

                <label class="form-label fw-medium small mb-1">Chọn ảnh phụ</label>
                <input type="file" name="subImages" id="subImages" accept="image/*" multiple
                       class="form-control form-control-sm" />
                <div class="form-text">Có thể chọn nhiều ảnh cùng lúc. JPG, PNG, WEBP – tối đa 5MB mỗi ảnh.</div>

                <div class="row g-2 mt-2" id="subPreviewList"></div>
            </div>

            <div class="content-card p-4 mb-3">
                <h6 class="fw-semibold mb-3">Phân loại</h6>

                <div class="mb-3">
                    <label asp-for="CategoryId" class="form-label fw-medium">Danh mục <span class="text-danger">*</span></label>
                    <select asp-for="CategoryId" class="form-select">
                        <option value="">-- Chọn danh mục --</option>
                        @foreach (var c in categories)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>
            </div>

            <div class="content-card p-4">
                <h6 class="fw-semibold mb-3">Tuỳ chọn</h6>

                <div class="form-check form-switch mb-2">
                    <input asp-for="IsFeatured" class="form-check-input" type="checkbox" />
                    <label asp-for="IsFeatured" class="form-check-label">Sản phẩm nổi bật</label>
                </div>
                <div class="form-check form-switch">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                    <label asp-for="IsActive" class="form-check-label">Đang bán</label>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 mt-3">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i>Lưu sản phẩm
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
    </div>
</form>

@section Scripts {
    <script>
        document.getElementById('subImages')?.addEventListener('change', function () {
            const preview = document.getElementById('subPreviewList');
            preview.innerHTML = '';
            Array.from(this.files).forEach(file => {
                const reader = new FileReader();
                reader.onload = e => {
                    const col = document.createElement('div');
                    col.className = 'col-4';
                    col.innerHTML = `
                        <div class="border rounded overflow-hidden" style="padding-top:75%;position:relative;">
                            <img src="${e.target.result}" class="position-absolute top-0 start-0 w-100 h-100"
                                 style="object-fit:cover;" />
                        </div>`;
                    preview.appendChild(col);
                };
                reader.readAsDataURL(file);
            });
        });
    </script>
}
