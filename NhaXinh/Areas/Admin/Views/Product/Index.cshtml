@using NhaXinh.Models
@model List<Product>

@{
    ViewData["Title"] = "Quản lý sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

    int totalCount = ViewBag.TotalCount ?? 0;
    string keyword = ViewBag.Keyword ?? "";
    int? catId = ViewBag.CategoryId;
    var categories = ViewBag.Categories as List<Category> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h5 class="fw-bold mb-0">Sản phẩm</h5>
        <small class="text-muted">@totalCount sản phẩm</small>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Thêm sản phẩm
    </a>
</div>

<div class="content-card p-3 mb-3">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-5">
            <input name="keyword" value="@keyword" class="form-control form-control-sm"
                   placeholder="Tìm theo tên sản phẩm..." />
        </div>
        <div class="col-md-4">
            <select name="categoryId" class="form-select form-select-sm">
                <option value="">-- Tất cả danh mục --</option>
                @foreach (var c in categories)
                {
                    <option value="@c.Id" selected="@(catId == c.Id)">@c.Name</option>
                }
            </select>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button class="btn btn-primary btn-sm w-100">
                <i class="bi bi-search me-1"></i>Tìm
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm w-100">
                <i class="bi bi-x-lg"></i>
            </a>
        </div>
    </form>
</div>

<div class="content-card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width:60px">Ảnh</th>
                    <th>Tên sản phẩm</th>
                    <th>Danh mục</th>
                    <th>Giá</th>
                    <th>Tồn kho</th>
                    <th>Nổi bật</th>
                    <th>Trạng thái</th>
                    <th style="width:120px">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center py-4 text-muted">
                            <i class="bi bi-inbox fs-4 d-block mb-1"></i>Không có sản phẩm nào
                        </td>
                    </tr>
                }
                @foreach (var p in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(p.MainImageUrl))
                            {
                                <img src="@p.MainImageUrl" alt="@p.Name"
                                     style="width:48px;height:48px;object-fit:cover;border-radius:6px;" />
                            }
                            else
                            {
                                <div class="bg-light rounded d-flex align-items-center justify-content-center"
                                     style="width:48px;height:48px;">
                                    <i class="bi bi-image text-muted"></i>
                                </div>
                            }
                        </td>
                        <td>
                            <div class="fw-semibold">@p.Name</div>
                            <small class="text-muted">@p.Slug</small>
                        </td>
                        <td>@p.Category?.Name</td>
                        <td>
                            @if (p.DiscountPrice.HasValue)
                            {
                                <div class="text-danger fw-semibold">@p.DiscountPrice.Value.ToString("N0")₫</div>
                                <small class="text-muted text-decoration-line-through">@p.Price.ToString("N0")₫</small>
                            }
                            else
                            {
                                <span>@p.Price.ToString("N0")₫</span>
                            }
                        </td>
                        <td>
                            <span class="@(p.StockQuantity <= 5 ? "text-danger fw-semibold" : "")">
                                @p.StockQuantity
                            </span>
                        </td>
                        <td>
                            @if (p.IsFeatured)
                            {
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-star-fill me-1"></i>Nổi bật
                                </span>
                            }
                        </td>
                        <td>
                            @if (p.IsActive)
                            {
                                <span class="badge bg-success">Đang bán</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Ẩn</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@p.Id"
                               class="btn btn-sm btn-outline-primary py-0 me-1" title="Sửa">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@p.Id"
                               class="btn btn-sm btn-outline-danger py-0" title="Xóa">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination" view-data="ViewData" />
</div>
