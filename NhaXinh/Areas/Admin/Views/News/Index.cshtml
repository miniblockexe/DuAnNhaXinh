@model List<NhaXinh.Models.News>

@{
    ViewData["Title"] = "Quản lý tin tức";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
    string? keyword = ViewBag.Keyword;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold"><i class="bi bi-newspaper me-2 text-primary"></i>Tin tức</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Thêm bài viết
    </a>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body py-2 px-3">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="keyword" value="@keyword"
                   class="form-control form-control-sm" placeholder="Tìm tiêu đề bài viết..." style="max-width:320px;" />
            <button class="btn btn-sm btn-outline-primary">
                <i class="bi bi-search"></i> Tìm
            </button>
            @if (!string.IsNullOrEmpty(keyword))
            {
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-x"></i> Xoá lọc
                </a>
            }
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width:60px">#</th>
                    <th style="width:80px" class="text-center">Ảnh</th>
                    <th>Tiêu đề</th>
                    <th style="width:110px" class="text-center">Tác giả</th>
                    <th style="width:100px" class="text-center">Nổi bật</th>
                    <th style="width:100px" class="text-center">Trạng thái</th>
                    <th style="width:130px" class="text-center">Ngày tạo</th>
                    <th style="width:120px" class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                            Chưa có bài viết nào.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-muted">@item.Id</td>
                        <td class="text-center">
                            @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                            {
                                <img src="@item.ThumbnailUrl" alt="@item.Title"
                                     style="width:52px;height:40px;object-fit:cover;border-radius:6px;" />
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            <div class="fw-semibold">@item.Title</div>
                            <small class="text-muted">/@item.Slug</small>
                        </td>
                        <td class="text-center">
                            <small>@(item.Author ?? "—")</small>
                        </td>
                        <td class="text-center">
                            @if (item.IsFeatured)
                            {
                                <span class="badge bg-warning text-dark"><i class="bi bi-star-fill me-1"></i>Nổi bật</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (item.IsPublished)
                            {
                                <span class="badge bg-success">Đã đăng</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Nháp</span>
                            }
                        </td>
                        <td class="text-center">
                            <small>@item.CreatedAt.ToString("dd/MM/yyyy")</small>
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-primary me-1" title="Sửa">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Xoá bài viết «@item.Title»?')">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger" title="Xoá">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<partial name="_Pagination" view-data="ViewData" />
