@model NhaXinh.Models.News

@{
    ViewData["Title"] = "Sửa bài viết";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h4 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2 text-primary"></i>Sửa bài viết</h4>
</div>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="CreatedAt" />
    <input type="hidden" name="existingThumbnail" value="@Model.ThumbnailUrl" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

    <div class="row g-4">

        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body p-4">

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold">Tiêu đề <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control" id="titleInput" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Slug" class="form-label fw-semibold">
                            Slug <small class="text-muted fw-normal">(để trống sẽ tự tạo)</small>
                        </label>
                        <input asp-for="Slug" class="form-control font-monospace" id="slugInput" data-edit-mode="1" />
                        <span asp-validation-for="Slug" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Summary" class="form-label fw-semibold">Tóm tắt</label>
                        <textarea asp-for="Summary" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Summary" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Content" class="form-label fw-semibold">Nội dung <span class="text-danger">*</span></label>
                        <textarea asp-for="Content" class="form-control" rows="12"></textarea>
                        <span asp-validation-for="Content" class="text-danger small"></span>
                    </div>

                </div>
            </div>
        </div>

        <div class="col-lg-4">

            <div class="card shadow-sm mb-3">
                <div class="card-header fw-semibold py-2">
                    <i class="bi bi-image me-1"></i> Ảnh đại diện
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
                    {
                        <div class="mb-2">
                            <img src="@Model.ThumbnailUrl" alt="Thumbnail hiện tại"
                                 class="rounded border w-100"
                                 style="max-height:160px;object-fit:cover;"
                                 id="imgPreview" />
                        </div>
                        <small class="text-muted d-block mb-2">Chọn ảnh mới để thay thế</small>
                    }
                    else
                    {
                        <img id="imgPreview" src="#" alt="Preview"
                             class="d-none rounded border w-100 mb-2"
                             style="max-height:160px;object-fit:cover;" />
                    }
                    <input type="file" name="thumbnailFile" accept="image/*" class="form-control form-control-sm"
                           onchange="previewImg(this,'imgPreview')" />
                    @Html.ValidationMessage("thumbnailFile", new { @class = "text-danger small" })
                </div>
            </div>

            <div class="card shadow-sm mb-3">
                <div class="card-header fw-semibold py-2">
                    <i class="bi bi-info-circle me-1"></i> Thông tin
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Author" class="form-label fw-semibold">Tác giả</label>
                        <input asp-for="Author" class="form-control form-control-sm" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="PublishedAt" class="form-label fw-semibold">Ngày đăng</label>
                        <input asp-for="PublishedAt" type="datetime-local" class="form-control form-control-sm" />
                    </div>
                    <div class="text-muted small">
                        <i class="bi bi-calendar3 me-1"></i>
                        Tạo lúc: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-3">
                <div class="card-header fw-semibold py-2">
                    <i class="bi bi-toggles me-1"></i> Tuỳ chọn
                </div>
                <div class="card-body d-flex flex-column gap-2">
                    <div class="form-check form-switch">
                        <input asp-for="IsPublished" class="form-check-input" role="switch" />
                        <label asp-for="IsPublished" class="form-check-label">Công khai bài viết</label>
                    </div>
                    <div class="form-check form-switch">
                        <input asp-for="IsFeatured" class="form-check-input" role="switch" />
                        <label asp-for="IsFeatured" class="form-check-label">Bài viết nổi bật</label>
                    </div>
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save me-1"></i> Lưu thay đổi
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Huỷ</a>
            </div>

        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
