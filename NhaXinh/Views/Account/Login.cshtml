@model NhaXinh.ViewModels.Account.LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<section class="nx-auth-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-7 col-lg-5">

                <div class="nx-auth-card">
                    <div class="nx-auth-card__header text-center">
                        <div class="nx-auth-card__logo">
                            <i class="bi bi-house-heart-fill"></i>
                        </div>
                        <h1 class="nx-auth-card__title">Đăng nhập</h1>
                        <p class="nx-auth-card__subtitle">Chào mừng trở lại với <strong>Nhà Xinh</strong></p>
                    </div>

                    <div class="nx-auth-card__body">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert nx-alert-error d-flex align-items-center gap-2 mb-4">
                                <i class="bi bi-exclamation-circle-fill"></i>
                                <div>
                                    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                    {
                                        <div>@err.ErrorMessage</div>
                                    }
                                </div>
                            </div>
                        }

                        <form asp-action="Login" asp-controller="Account" method="post" novalidate>
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="ReturnUrl" />

                            <div class="nx-form-group">
                                <label asp-for="Email" class="nx-form-label">
                                    <i class="bi bi-envelope me-1"></i>Email
                                </label>
                                <input asp-for="Email" class="nx-form-control"
                                       type="email" placeholder="example@email.com"
                                       autocomplete="email" />
                                <span asp-validation-for="Email" class="nx-form-error"></span>
                            </div>

                            <div class="nx-form-group">
                                <label asp-for="Password" class="nx-form-label">
                                    <i class="bi bi-lock me-1"></i>Mật khẩu
                                </label>
                                <div class="nx-input-password-wrap">
                                    <input asp-for="Password" class="nx-form-control"
                                           id="passwordInput" type="password"
                                           placeholder="••••••••"
                                           autocomplete="current-password" />
                                    <button type="button" class="nx-input-password-toggle"
                                            onclick="togglePassword()" aria-label="Hiện/ẩn mật khẩu">
                                        <i class="bi bi-eye" id="eyeIcon"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="nx-form-error"></span>
                            </div>

                            <div class="d-flex align-items-center justify-content-between mb-4">
                                <div class="form-check nx-form-check">
                                    <input class="form-check-input nx-check" type="checkbox"
                                           asp-for="RememberMe" id="rememberMe" />
                                    <label class="form-check-label nx-form-check-label" for="rememberMe">
                                        Ghi nhớ đăng nhập
                                    </label>
                                </div>
                            </div>

                            <button type="submit" class="nx-btn-auth w-100">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                            </button>
                        </form>

                        <div class="nx-auth-divider">
                            <span>Chưa có tài khoản?</span>
                        </div>

                        <a asp-controller="Account" asp-action="Register"
                           class="nx-btn-auth-outline w-100 text-center d-block">
                            <i class="bi bi-person-plus me-2"></i>Tạo tài khoản mới
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>


@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
