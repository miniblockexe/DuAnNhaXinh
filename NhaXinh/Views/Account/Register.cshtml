@model NhaXinh.ViewModels.Account.RegisterViewModel

@{
    ViewData["Title"] = "Đăng ký tài khoản";
}

<section class="nx-auth-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-8 col-lg-6">

                <div class="nx-auth-card">
                    <div class="nx-auth-card__header text-center">
                        <div class="nx-auth-card__logo">
                            <i class="bi bi-person-plus-fill"></i>
                        </div>
                        <h1 class="nx-auth-card__title">Tạo tài khoản</h1>
                        <p class="nx-auth-card__subtitle">Tham gia cùng <strong>Nhà Xinh</strong> ngay hôm nay</p>
                    </div>

                    <div class="nx-auth-card__body">

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert nx-alert-error d-flex align-items-start gap-2 mb-4">
                                <i class="bi bi-exclamation-circle-fill mt-1"></i>
                                <div>
                                    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                    {
                                        <div>@err.ErrorMessage</div>
                                    }
                                </div>
                            </div>
                        }

                        <form asp-action="Register" asp-controller="Account" method="post" novalidate>
                            @Html.AntiForgeryToken()

                            <div class="nx-form-group">
                                <label asp-for="FullName" class="nx-form-label">
                                    <i class="bi bi-person me-1"></i>Họ và tên
                                </label>
                                <input asp-for="FullName" class="nx-form-control"
                                       type="text" placeholder="Nguyễn Văn A"
                                       autocomplete="name" />
                                <span asp-validation-for="FullName" class="nx-form-error"></span>
                            </div>

                            <div class="nx-form-group">
                                <label asp-for="Email" class="nx-form-label">
                                    <i class="bi bi-envelope me-1"></i>Email
                                </label>
                                <input asp-for="Email" class="nx-form-control"
                                       type="email" placeholder="example@email.com"
                                       autocomplete="email" />
                                <span asp-validation-for="Email" class="nx-form-error"></span>
                            </div>

                            <div class="nx-form-group">
                                <label asp-for="PhoneNumber" class="nx-form-label">
                                    <i class="bi bi-telephone me-1"></i>Số điện thoại
                                    <span class="nx-form-label-optional">(tuỳ chọn)</span>
                                </label>
                                <input asp-for="PhoneNumber" class="nx-form-control"
                                       type="tel" placeholder="0901 234 567"
                                       autocomplete="tel" />
                                <span asp-validation-for="PhoneNumber" class="nx-form-error"></span>
                            </div>

                            <div class="nx-form-group">
                                <label asp-for="Password" class="nx-form-label">
                                    <i class="bi bi-lock me-1"></i>Mật khẩu
                                </label>
                                <div class="nx-input-password-wrap">
                                    <input asp-for="Password" class="nx-form-control"
                                           id="passwordInput" type="password"
                                           placeholder="Tối thiểu 6 ký tự"
                                           autocomplete="new-password" />
                                    <button type="button" class="nx-input-password-toggle"
                                            onclick="togglePassword('passwordInput','eyeIcon1')"
                                            aria-label="Hiện/ẩn mật khẩu">
                                        <i class="bi bi-eye" id="eyeIcon1"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="nx-form-error"></span>
                            </div>

                            <div class="nx-form-group">
                                <label asp-for="ConfirmPassword" class="nx-form-label">
                                    <i class="bi bi-lock-fill me-1"></i>Xác nhận mật khẩu
                                </label>
                                <div class="nx-input-password-wrap">
                                    <input asp-for="ConfirmPassword" class="nx-form-control"
                                           id="confirmPasswordInput" type="password"
                                           placeholder="Nhập lại mật khẩu"
                                           autocomplete="new-password" />
                                    <button type="button" class="nx-input-password-toggle"
                                            onclick="togglePassword('confirmPasswordInput','eyeIcon2')"
                                            aria-label="Hiện/ẩn mật khẩu">
                                        <i class="bi bi-eye" id="eyeIcon2"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="ConfirmPassword" class="nx-form-error"></span>
                            </div>

                            <button type="submit" class="nx-btn-auth w-100 mt-2">
                                <i class="bi bi-person-check me-2"></i>Tạo tài khoản
                            </button>
                        </form>

                        <div class="nx-auth-divider">
                            <span>Đã có tài khoản?</span>
                        </div>

                        <a asp-controller="Account" asp-action="Login"
                           class="nx-btn-auth-outline w-100 text-center d-block">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                        </a>

                    </div>
                </div>

            </div>
        </div>
    </div>
</section>


@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
