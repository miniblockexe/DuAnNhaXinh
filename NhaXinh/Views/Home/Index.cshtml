@model NhaXinh.ViewModels.Home.HomeViewModel

@{
    ViewData["Title"] = "Trang chủ";
}

@if (Model.Banners.Any())
{
    <section class="nx-hero">
        <div id="heroBannerCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="5000">

            <div class="carousel-indicators">
                @for (int i = 0; i < Model.Banners.Count; i++)
                {
                    <button type="button" data-bs-target="#heroBannerCarousel"
                            data-bs-slide-to="@i"
                            class="@(i == 0 ? "active" : "")"
                            aria-label="Slide @(i+1)"></button>
                }
            </div>

            <div class="carousel-inner">
                @for (int i = 0; i < Model.Banners.Count; i++)
                {
                    var banner = Model.Banners[i];
                    <div class="carousel-item @(i == 0 ? "active" : "")">
                        <div class="nx-hero__slide"
                             style="background-image: url('@(banner.ImageUrl ?? "/images/banners/default.jpg")')">
                            <div class="nx-hero__overlay"></div>
                            <div class="nx-hero__content container">
                                @if (!string.IsNullOrEmpty(banner.Title))
                                {
                                    <h1 class="nx-hero__title">@banner.Title</h1>
                                }
                                @if (!string.IsNullOrEmpty(banner.SubTitle))
                                {
                                    <p class="nx-hero__subtitle">@banner.SubTitle</p>
                                }
                                @if (!string.IsNullOrEmpty(banner.LinkUrl))
                                {
                                    <a href="@banner.LinkUrl" class="nx-hero__cta">
                                        Khám phá ngay <i class="bi bi-arrow-right ms-2"></i>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <button class="carousel-control-prev nx-carousel-btn" type="button"
                    data-bs-target="#heroBannerCarousel" data-bs-slide="prev">
                <i class="bi bi-chevron-left"></i>
            </button>
            <button class="carousel-control-next nx-carousel-btn" type="button"
                    data-bs-target="#heroBannerCarousel" data-bs-slide="next">
                <i class="bi bi-chevron-right"></i>
            </button>
        </div>
    </section>
}
else
{
    <section class="nx-hero nx-hero--fallback">
        <div class="nx-hero__overlay"></div>
        <div class="nx-hero__content container">
            <h1 class="nx-hero__title">Không gian sống<br>tinh tế, đẳng cấp</h1>
            <p class="nx-hero__subtitle">Nội thất cao cấp — Thiết kế hiện đại — Chất lượng vượt trội</p>
            <a asp-controller="Product" asp-action="Index" class="nx-hero__cta">
                Xem bộ sưu tập <i class="bi bi-arrow-right ms-2"></i>
            </a>
        </div>
    </section>
}

<div class="nx-trustbar">
    <div class="container">
        <div class="nx-trustbar__inner">
            <div class="nx-trustbar__item">
                <i class="bi bi-truck"></i>
                <span>Miễn phí vận chuyển nội thành</span>
            </div>
            <div class="nx-trustbar__divider"></div>
            <div class="nx-trustbar__item">
                <i class="bi bi-shield-check"></i>
                <span>Bảo hành chính hãng 12 tháng</span>
            </div>
            <div class="nx-trustbar__divider"></div>
            <div class="nx-trustbar__item">
                <i class="bi bi-arrow-counterclockwise"></i>
                <span>Đổi trả trong 30 ngày</span>
            </div>
            <div class="nx-trustbar__divider"></div>
            <div class="nx-trustbar__item">
                <i class="bi bi-headset"></i>
                <span>Hỗ trợ 24/7</span>
            </div>
        </div>
    </div>
</div>

@if (Model.Categories.Any())
{
    <section class="nx-section nx-section--categories">
        <div class="container">
            <div class="nx-section-header">
                <h2 class="nx-section-title">Danh mục nổi bật</h2>
                <p class="nx-section-sub">Tìm kiếm sản phẩm theo không gian sống của bạn</p>
            </div>

            <div class="row g-3 justify-content-center">
                @foreach (var cat in Model.Categories.Where(c => c.ParentId == null).Take(6))
                {
                    string catImg = !string.IsNullOrEmpty(cat.ImageUrl)
                    ? cat.ImageUrl
                    : "/images/defaults/category.jpg";

                    <div class="col-6 col-sm-4 col-lg-2">
                        <a asp-controller="Product" asp-action="Index"
                           asp-route-categoryId="@cat.Id"
                           class="nx-cat-card text-decoration-none">
                            <div class="nx-cat-card__img-wrap">
                                <img src="@catImg" alt="@cat.Name"
                                     class="nx-cat-card__img" loading="lazy" />
                            </div>
                            <span class="nx-cat-card__name">@cat.Name</span>
                        </a>
                    </div>
                }
            </div>
        </div>
    </section>
}

@if (Model.FeaturedProducts.Any())
{
    <section class="nx-section nx-section--products">
        <div class="container">
            <div class="nx-section-header d-flex align-items-end justify-content-between flex-wrap gap-2">
                <div>
                    <h2 class="nx-section-title mb-1">Sản phẩm nổi bật</h2>
                    <p class="nx-section-sub mb-0">Những sản phẩm được yêu thích nhất</p>
                </div>
                <a asp-controller="Product" asp-action="Index" class="nx-link-see-all">
                    Xem tất cả <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>

            <div class="row g-4 mt-1">
                @foreach (var product in Model.FeaturedProducts)
                {
                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        @await Html.PartialAsync("_ProductCard", product)
                    </div>
                }
            </div>
        </div>
    </section>
}

<section class="nx-banner-strip">
    <div class="container">
        <div class="row g-0">
            <div class="nx-banner-strip__left col-12 col-md-7">
                <div class="nx-banner-strip__content">
                    <span class="nx-banner-strip__tag">Bộ sưu tập mới</span>
                    <h2 class="nx-banner-strip__title">Không gian sống<br>mang phong cách riêng</h2>
                    <p class="nx-banner-strip__text">Khám phá hơn 500 mẫu nội thất cao cấp từ các thương hiệu uy tín trong và ngoài nước.</p>
                    <a asp-controller="Product" asp-action="Index" class="nx-banner-strip__btn">
                        Mua sắm ngay
                    </a>
                </div>
            </div>
            <div class="nx-banner-strip__right col-12 col-md-5 d-none d-md-block">
                <img src="/images/banners/strip-banner.jpg" alt="Nội thất cao cấp"
                     class="nx-banner-strip__img"
                     onerror="this.style.display='none'" />
            </div>
        </div>
    </div>
</section>

<section class="nx-section nx-section--why">
    <div class="container">
        <div class="nx-section-header text-center">
            <h2 class="nx-section-title">Tại sao chọn Nhà Xinh?</h2>
        </div>
        <div class="row g-4">
            @{
                var whys = new[] {
            new { Icon = "bi-award",         Title = "Chất lượng cao cấp",   Desc = "Chọn lọc kỹ càng từ các nhà sản xuất uy tín, đảm bảo độ bền và thẩm mỹ." },
            new { Icon = "bi-brush",      Title = "Thiết kế tinh tế",     Desc = "Đa dạng phong cách từ hiện đại, tối giản đến cổ điển, phù hợp mọi không gian." },
            new { Icon = "bi-people",        Title = "Tư vấn tận tình",     Desc = "Đội ngũ chuyên gia nội thất sẵn sàng hỗ trợ bạn tạo nên không gian mơ ước." },
            new { Icon = "bi-percent",     Title = "Giá cả hợp lý",      Desc = "Cam kết mức giá cạnh tranh, thường xuyên có ưu đãi và chương trình khuyến mãi." },
            };
            }
            @foreach (var item in whys)
            {
                <div class="col-12 col-sm-6 col-lg-3">
                    <div class="nx-why-card">
                        <div class="nx-why-card__icon">
                            <i class="bi @item.Icon"></i>
                        </div>
                        <h4 class="nx-why-card__title">@item.Title</h4>
                        <p class="nx-why-card__text">@item.Desc</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/home.css" asp-append-version="true" />
}
