<footer class="nx-footer">
    <div class="container">
        <div class="row g-5">

            <div class="col-12 col-md-6 col-lg-3">
                <div class="nx-logo mb-3">
                    <span class="nx-logo__text">Nhà Xinh</span>
                </div>
                <p class="nx-footer__desc">
                    Chuyên cung cấp nội thất hiện đại, tối giản — nơi không gian sống trở thành
                    câu chuyện của chính bạn.
                </p>
                <div class="d-flex gap-3 mt-4">
                    <a href="https://www.facebook.com/tran.tam.625434" class="nx-social-btn" target="_blank" rel="noopener" aria-label="Facebook">
                        <i class="bi bi-facebook"></i>
                    </a>
                    <a href="https://instagram.com" class="nx-social-btn" target="_blank" rel="noopener" aria-label="Instagram">
                        <i class="bi bi-instagram"></i>
                    </a>
                    <a href="https://zalo.me" class="nx-social-btn" target="_blank" rel="noopener" aria-label="Zalo">
                        <i class="bi bi-chat-dots"></i>
                    </a>
                    <a href="https://youtube.com" class="nx-social-btn" target="_blank" rel="noopener" aria-label="YouTube">
                        <i class="bi bi-youtube"></i>
                    </a>
                </div>
            </div>

            <div class="col-6 col-lg-2">
                <h6 class="nx-footer__heading">Khám phá</h6>
                <ul class="nx-footer__links">
                    <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li><a asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
                    <li><a asp-controller="News" asp-action="Index">Tin tức</a></li>
                    <li><a asp-controller="Home" asp-action="Privacy">Chính sách</a></li>
                </ul>
            </div>

            <div class="col-6 col-lg-2">
                <h6 class="nx-footer__heading">Hỗ trợ</h6>
                <ul class="nx-footer__links">
                    <li><a asp-controller="Account" asp-action="Login">Đăng nhập</a></li>
                    <li><a asp-controller="Account" asp-action="Register">Đăng ký</a></li>
                    <li><a asp-controller="Order" asp-action="History">Đơn hàng</a></li>
                    <li><a asp-controller="Cart" asp-action="Index">Giỏ hàng</a></li>
                </ul>
            </div>

            <div class="col-12 col-lg-4">
                <h6 class="nx-footer__heading">Liên hệ</h6>
                <ul class="nx-footer__contact">
                    <li>
                        <i class="bi bi-geo-alt"></i>
                        <span>123 Đường Nội Thất, Quận 1, TP. Hồ Chí Minh</span>
                    </li>
                    <li>
                        <i class="bi bi-telephone"></i>
                        <a href="tel:0901234567">0901 234 567</a>
                    </li>
                    <li>
                        <i class="bi bi-envelope"></i>
                        <a href="mailto:hello@nhaxinh.vn">hello&#64;nhaxinh.vn</a>
                    </li>
                    <li>
                        <i class="bi bi-clock"></i>
                        <span>Thứ 2 – Thứ 7: 8:00 – 20:00</span>
                    </li>
                </ul>
            </div>
        </div>

        <hr class="nx-footer__divider" />

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2 pb-4">
            <p class="nx-footer__copy mb-0">
                &copy; @DateTime.Now.Year <strong>Nhà Xinh</strong>. Bảo lưu mọi quyền.
            </p>
            <div class="d-flex gap-3">
                <a class="nx-footer__policy" asp-controller="Home" asp-action="Privacy">Chính sách bảo mật</a>
                <span class="nx-footer__policy">|</span>
                <a class="nx-footer__policy" href="#">Điều khoản sử dụng</a>
            </div>
        </div>
    </div>
</footer>
