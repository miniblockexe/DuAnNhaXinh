@model List<NhaXinh.Models.Banner>

@if (Model == null || !Model.Any())
{
    return;
}

@{
    var activeBanners = Model.Where(b => b.IsActive).OrderBy(b => b.DisplayOrder).ToList();
}

@if (!activeBanners.Any())
{
    return;
}

<section class="nx-banner">
    <div id="bannerCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="5000">

        @if (activeBanners.Count > 1)
        {
            <div class="carousel-indicators">
                @for (int i = 0; i < activeBanners.Count; i++)
                {
                    <button type="button"
                            data-bs-target="#bannerCarousel"
                            data-bs-slide-to="@i"
                            class="@(i == 0 ? "active" : "")"
                            aria-label="Slide @(i + 1)"></button>
                }
            </div>
        }

        <div class="carousel-inner">
            @for (int i = 0; i < activeBanners.Count; i++)
            {
                var banner = activeBanners[i];
                <div class="carousel-item nx-banner__item @(i == 0 ? "active" : "")">
                    <img src="@banner.ImageUrl"
                         class="nx-banner__img d-block w-100"
                         alt="@banner.Title"
                         loading="@(i == 0 ? "eager" : "lazy")" />

                    <div class="carousel-caption nx-banner__caption">
                        <h2 class="nx-banner__title">@banner.Title</h2>
                        @if (!string.IsNullOrEmpty(banner.SubTitle))
                        {
                            <p class="nx-banner__subtitle">@banner.SubTitle</p>
                        }
                        @if (!string.IsNullOrEmpty(banner.LinkUrl))
                        {
                            <a href="@banner.LinkUrl" class="nx-btn-primary nx-banner__cta">
                                Khám phá ngay
                            </a>
                        }
                    </div>
                </div>
            }
        </div>

        @if (activeBanners.Count > 1)
        {
            <button class="carousel-control-prev nx-banner__control" type="button"
                    data-bs-target="#bannerCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Trước</span>
            </button>
            <button class="carousel-control-next nx-banner__control" type="button"
                    data-bs-target="#bannerCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Tiếp</span>
            </button>
        }
    </div>
</section>
