@model NhaXinh.ViewModels.Product.ProductListViewModel

@{
    ViewData["Title"] = "Sản phẩm";
    ViewData["CategoryId"] = Model.CategoryId;
    var selectedCat = Model.Categories.FirstOrDefault(c => c.Id == Model.CategoryId);
}

<section class="nx-product-list-section">
    <div class="container">

        <div class="nx-page-header mb-4 pt-4">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb nx-breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="breadcrumb-item active">
                        @(selectedCat != null ? selectedCat.Name : "Tất cả sản phẩm")
                    </li>
                </ol>
            </nav>
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                <h1 class="nx-page-title">
                    @(selectedCat != null ? selectedCat.Name : "Tất cả sản phẩm")
                    @if (Model.TotalCount > 0)
                    {
                        <span class="nx-count-badge">@Model.TotalCount sản phẩm</span>
                    }
                </h1>
            </div>
        </div>

        @if (Model.Categories.Any())
        {
            <div class="nx-cat-pills-wrap mb-4">
                @await Html.PartialAsync("_CategoryMenu", Model.Categories)
            </div>
        }

        <div class="row g-4">

            <div class="col-12 col-lg-3">
                <aside class="nx-filter-sidebar">
                    <div class="nx-filter-sidebar__header">
                        <i class="bi bi-sliders2 me-2"></i>Bộ lọc
                        @if (Model.CategoryId.HasValue || !string.IsNullOrEmpty(Model.Keyword) ||
                        Model.MinPrice.HasValue || Model.MaxPrice.HasValue)
                        {
                            <a asp-action="Index" class="nx-filter-sidebar__clear ms-auto">
                                <i class="bi bi-x-circle me-1"></i>Xóa lọc
                            </a>
                        }
                    </div>

                    <form asp-action="Index" asp-controller="Product" method="get"
                          id="filterForm" class="nx-filter-form">

                        <div class="nx-filter-group">
                            <label class="nx-filter-label">Tìm kiếm</label>
                            <div class="nx-search-wrap">
                                <input type="text" name="keyword" class="nx-filter-input"
                                       value="@Model.Keyword" placeholder="Tên sản phẩm..." />
                                <button type="submit" class="nx-search-btn">
                                    <i class="bi bi-search"></i>
                                </button>
                            </div>
                        </div>

                        @if (Model.Categories.Any())
                        {
                            <div class="nx-filter-group">
                                <label class="nx-filter-label">Danh mục</label>
                                <div class="nx-filter-cat-list">
                                    <label class="nx-filter-cat-item">
                                        <input type="radio" name="categoryId" value=""
                                        @(Model.CategoryId == null ? "checked" : "")
                                               onchange="this.form.submit()" />
                                        <span>Tất cả danh mục</span>
                                    </label>
                                    @foreach (var cat in Model.Categories.Where(c => c.ParentId == null).OrderBy(c => c.DisplayOrder))
                                    {
                                        <label class="nx-filter-cat-item">
                                            <input type="radio" name="categoryId" value="@cat.Id"
                                            @(Model.CategoryId == cat.Id ? "checked" : "")
                                                   onchange="this.form.submit()" />
                                            <span>@cat.Name</span>
                                        </label>
                                    }
                                </div>
                            </div>
                        }

                        <div class="nx-filter-group">
                            <label class="nx-filter-label">Khoảng giá (₫)</label>
                            <div class="row g-2">
                                <div class="col-6">
                                    <input type="number" name="minPrice" class="nx-filter-input"
                                           placeholder="Từ" value="@Model.MinPrice"
                                           min="0" step="500000" />
                                </div>
                                <div class="col-6">
                                    <input type="number" name="maxPrice" class="nx-filter-input"
                                           placeholder="Đến" value="@Model.MaxPrice"
                                           min="0" step="500000" />
                                </div>
                            </div>
                            <div class="nx-price-presets mt-2 d-flex flex-wrap gap-1">
                                @{
                                    var priceRanges = new[] {
                                new { Label = "Dưới 5tr",    Min = (decimal?)null,  Max = (decimal?)5000000  },
                                new { Label = "5–15tr",      Min = (decimal?)5000000, Max = (decimal?)15000000 },
                                new { Label = "15–30tr",     Min = (decimal?)15000000, Max = (decimal?)30000000 },
                                new { Label = "Trên 30tr",   Min = (decimal?)30000000, Max = (decimal?)null  },
                                };
                                }
                                @foreach (var r in priceRanges)
                                {
                                    bool active = Model.MinPrice == r.Min && Model.MaxPrice == r.Max;
                                    <a href="@Url.Action("Index", new {
                                        categoryId = Model.CategoryId,
                                        keyword = Model.Keyword,
                                        sortBy = Model.SortBy,
                                        minPrice = r.Min,
                                        maxPrice = r.Max })"
                                       class="nx-price-preset @(active ? "active" : "")">@r.Label</a>
                                }
                            </div>
                        </div>

                        @if (Model.CategoryId.HasValue)
                        {
                            <input type="hidden" name="categoryId" value="@Model.CategoryId" />
                        }
                        @if (!string.IsNullOrEmpty(Model.SortBy))
                        {
                            <input type="hidden" name="sortBy" value="@Model.SortBy" />
                        }

                        <button type="submit" class="nx-btn-filter w-100 mt-3">
                            <i class="bi bi-funnel me-2"></i>Áp dụng
                        </button>
                    </form>
                </aside>
            </div>

            <div class="col-12 col-lg-9">

                <div class="nx-sort-bar mb-4">
                    <span class="nx-sort-bar__count d-none d-md-inline">
                        @Model.TotalCount kết quả
                    </span>
                    <div class="nx-sort-bar__right ms-auto d-flex align-items-center gap-2">
                        <span class="nx-sort-bar__label">Sắp xếp:</span>
                        @{
                            var sorts = new[] {
                        new { Value = "",            Label = "Mặc định"  },
                        new { Value = "price_asc",   Label = "Giá tăng"  },
                        new { Value = "price_desc",  Label = "Giá giảm"  },
                        new { Value = "newest",      Label = "Mới nhất"  },
                        new { Value = "popular",     Label = "Phổ biến"  },
                        };
                        }
                        @foreach (var s in sorts)
                        {
                            bool isCur = (Model.SortBy ?? "") == s.Value;
                            <a href="@Url.Action("Index", new {
                                   categoryId = Model.CategoryId,
                                   keyword = Model.Keyword,
                                   sortBy = s.Value,
                                   minPrice = Model.MinPrice,
                                   maxPrice = Model.MaxPrice })"
                               class="nx-sort-btn @(isCur ? "active" : "")">@s.Label</a>
                        }
                    </div>
                </div>

                @if (Model.Products.Any())
                {
                    <div class="row g-4">
                        @foreach (var product in Model.Products)
                        {
                            <div class="col-12 col-sm-6 col-xl-4">
                                @await Html.PartialAsync("_ProductCard", product)
                            </div>
                        }
                    </div>

                    @if (Model.TotalPages > 1)
                    {
                        <nav class="nx-pagination-wrap mt-5" aria-label="Phân trang">
                            <ul class="nx-pagination list-unstyled d-flex justify-content-center gap-1 mb-0">

                                @if (Model.CurrentPage > 1)
                                {
                                    <li>
                                        <a class="nx-page-btn"
                                           href="@Url.Action("Index", new { categoryId = Model.CategoryId, keyword = Model.Keyword, sortBy = Model.SortBy, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, page = Model.CurrentPage - 1 })">
                                            <i class="bi bi-chevron-left"></i>
                                        </a>
                                    </li>
                                }

                                @for (int p = Math.Max(1, Model.CurrentPage - 2);
                               p <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); p++)
                                {
                                    bool isActive = p == Model.CurrentPage;
                                    <li>
                                        <a class="nx-page-btn @(isActive ? "active" : "")"
                                           href="@Url.Action("Index", new { categoryId = Model.CategoryId, keyword = Model.Keyword, sortBy = Model.SortBy, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, page = p })">
                                            @p
                                        </a>
                                    </li>
                                }

                                @if (Model.CurrentPage < Model.TotalPages)
                                {
                                    <li>
                                        <a class="nx-page-btn"
                                           href="@Url.Action("Index", new { categoryId = Model.CategoryId, keyword = Model.Keyword, sortBy = Model.SortBy, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, page = Model.CurrentPage + 1 })">
                                            <i class="bi bi-chevron-right"></i>
                                        </a>
                                    </li>
                                }
                            </ul>
                            <p class="text-center nx-pagination-info mt-2">
                                Trang @Model.CurrentPage / @Model.TotalPages
                            </p>
                        </nav>
                    }
                }
                else
                {
                    <div class="nx-empty-state">
                        <i class="bi bi-inbox nx-empty-state__icon"></i>
                        <h3 class="nx-empty-state__title">Không tìm thấy sản phẩm</h3>
                        <p class="nx-empty-state__text">Thử thay đổi bộ lọc hoặc từ khóa tìm kiếm.</p>
                        <a asp-action="Index" class="nx-btn-reset">
                            <i class="bi bi-arrow-counterclockwise me-2"></i>Xem tất cả sản phẩm
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/product-list.css" asp-append-version="true" />
}
